{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/commitment_vector_manifest.schema.json",
  "title": "TrackOne commitment vector manifest",
  "type": "object",
  "description": "Portable manifest for the published TrackOne canonical CBOR commitment vector corpus.",
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "commitment_profile_id": {
      "type": "string",
      "const": "trackone-canonical-cbor-v1",
      "description": "Claim-bound commitment profile identifier for this conformance corpus; it is not embedded in the fact/day/Merkle preimages."
    },
    "cddl_profile": {
      "type": "string"
    },
    "manifest_schema": {
      "type": "string"
    },
    "fact_json_schema": {
      "type": "string"
    },
    "fact_cbor_shape": {
      "type": "string",
      "const": "fact-json-projection-v1"
    },
    "day_record_cbor_shape": {
      "type": "string",
      "const": "day-record-v1"
    },
    "cbor_profile": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "const": "trackone-deterministic-json-cbor-v1"
        },
        "map_key_order": {
          "type": "string",
          "const": "encoded-key-length-then-utf8-bytes"
        },
        "integer_encoding": {
          "type": "string",
          "const": "shortest-form"
        },
        "float_encoding": {
          "type": "string",
          "const": "shortest-exact-float16-float32-float64"
        },
        "non_finite_floats": {
          "type": "string",
          "const": "invalid"
        }
      },
      "required": [
        "id",
        "map_key_order",
        "integer_encoding",
        "float_encoding",
        "non_finite_floats"
      ],
      "additionalProperties": false
    },
    "profile_constraints": {
      "type": "object",
      "properties": {
        "integer_ranges": {
          "type": "object",
          "properties": {
            "json_integer": {
              "type": "string",
              "const": "signed-or-unsigned-64-bit"
            },
            "signed_min": {
              "type": "integer",
              "const": -9223372036854775808
            },
            "unsigned_max": {
              "type": "integer",
              "const": 18446744073709551615
            },
            "out_of_range": {
              "type": "string",
              "const": "invalid"
            }
          },
          "required": [
            "json_integer",
            "signed_min",
            "unsigned_max",
            "out_of_range"
          ],
          "additionalProperties": false
        },
        "timestamp_representation": {
          "type": "object",
          "properties": {
            "fact_projection": {
              "type": "string",
              "const": "rfc3339-utc-z-text"
            },
            "day_labels": {
              "type": "string",
              "const": "yyyy-mm-dd-utc-text"
            },
            "runtime_fact_schema": {
              "type": "string",
              "const": "integer-unix-seconds-not-used-by-this-vector-projection"
            }
          },
          "required": [
            "fact_projection",
            "day_labels",
            "runtime_fact_schema"
          ],
          "additionalProperties": false
        },
        "null_vs_absent": {
          "type": "object",
          "properties": {
            "pod_time": {
              "type": "string",
              "const": "required-nullable"
            },
            "optional_fields": {
              "type": "string",
              "const": "omit-when-unset"
            },
            "null_encoding": {
              "type": "string",
              "const": "cbor-null-only-when-json-field-is-present-null"
            }
          },
          "required": [
            "pod_time",
            "optional_fields",
            "null_encoding"
          ],
          "additionalProperties": false
        },
        "bytes_representation": {
          "type": "object",
          "properties": {
            "artifact_files": {
              "type": "string",
              "const": "raw-bytes"
            },
            "digests": {
              "type": "string",
              "const": "lowercase-hex-text"
            },
            "json_projection_bytes": {
              "type": "string",
              "const": "not-used"
            },
            "lower_level_bstr": {
              "type": "string",
              "const": "only-in-positional-runtime-cddl-shapes"
            }
          },
          "required": [
            "artifact_files",
            "digests",
            "json_projection_bytes",
            "lower_level_bstr"
          ],
          "additionalProperties": false
        },
        "unknown_fields": {
          "type": "object",
          "properties": {
            "fact_projection_top_level": {
              "type": "string",
              "const": "reject"
            },
            "block_header": {
              "type": "string",
              "const": "reject"
            },
            "day_record": {
              "type": "string",
              "const": "reject"
            },
            "manifest": {
              "type": "string",
              "const": "reject"
            },
            "payload": {
              "type": "string",
              "const": "allow-json-values"
            }
          },
          "required": [
            "fact_projection_top_level",
            "block_header",
            "day_record",
            "manifest",
            "payload"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "integer_ranges",
        "timestamp_representation",
        "null_vs_absent",
        "bytes_representation",
        "unknown_fields"
      ],
      "additionalProperties": false
    },
    "merkle_policy": {
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "const": "trackone-adr003-sha256-hash-sorted-v1"
        },
        "leaf_hash": {
          "type": "string",
          "const": "SHA-256(leaf_cbor_bytes)"
        },
        "leaf_order": {
          "type": "string",
          "const": "lexicographic-raw-32-byte-hash"
        },
        "parent_hash": {
          "type": "string",
          "const": "SHA-256(left || right)"
        },
        "odd_leaf": {
          "type": "string",
          "const": "duplicate-last"
        },
        "empty_root": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/hex64_lower"
        }
      },
      "required": [
        "id",
        "leaf_hash",
        "leaf_order",
        "parent_hash",
        "odd_leaf",
        "empty_root"
      ],
      "additionalProperties": false
    },
    "site_id": {
      "type": "string"
    },
    "date": {
      "type": "string"
    },
    "prev_day_root": {
      "$ref": "https://example.org/schemas/common.schema.json#/$defs/hex64_lower"
    },
    "batch_id": {
      "type": "string"
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "json_path": {
            "type": "string"
          },
          "cbor_path": {
            "type": "string"
          },
          "cbor_sha256": {
            "$ref": "https://example.org/schemas/common.schema.json#/$defs/hex64_lower"
          }
        },
        "required": [
          "name",
          "json_path",
          "cbor_path",
          "cbor_sha256"
        ],
        "additionalProperties": false
      }
    },
    "block_header_path": {
      "type": "string"
    },
    "day_record_json_path": {
      "type": "string"
    },
    "day_record_cbor_path": {
      "type": "string"
    },
    "leaf_hashes": {
      "type": "array",
      "items": {
        "$ref": "https://example.org/schemas/common.schema.json#/$defs/hex64_lower"
      }
    },
    "merkle_root": {
      "$ref": "https://example.org/schemas/common.schema.json#/$defs/hex64_lower"
    },
    "day_cbor_sha256": {
      "$ref": "https://example.org/schemas/common.schema.json#/$defs/hex64_lower"
    }
  },
  "required": [
    "version",
    "commitment_profile_id",
    "cddl_profile",
    "manifest_schema",
    "fact_json_schema",
    "fact_cbor_shape",
    "day_record_cbor_shape",
    "cbor_profile",
    "profile_constraints",
    "merkle_policy",
    "site_id",
    "date",
    "prev_day_root",
    "batch_id",
    "facts",
    "block_header_path",
    "day_record_json_path",
    "day_record_cbor_path",
    "leaf_hashes",
    "merkle_root",
    "day_cbor_sha256"
  ],
  "additionalProperties": false
}
