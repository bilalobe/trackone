{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/device_table.schema.json",
  "title": "Device Table",
  "type": "object",
  "properties": {
    "_meta": {
      "type": "object",
      "properties": {
        "master_seed": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/base64_string"
        },
        "version": {
          "const": "1.0"
        }
      },
      "required": [
        "master_seed",
        "version"
      ],
      "additionalProperties": false
    }
  },
  "$defs": {
    "device_entry": {
      "type": "object",
      "properties": {
        "salt8": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/base64_string"
        },
        "ck_up": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/base64_string"
        },
        "highest_fc_seen": {
          "type": [
            "integer",
            "number"
          ]
        },
        "last_seen": {
          "type": "string"
        },
        "msg_type": {
          "type": [
            "integer",
            "number"
          ]
        },
        "flags": {
          "type": [
            "integer",
            "number"
          ]
        },
        "deployment": {
          "type": "object",
          "description": "Legacy deployment metadata tolerated in persisted device tables so old captures remain readable."
        },
        "provisioning": {
          "type": "object",
          "description": "Legacy provisioning metadata tolerated in persisted device tables so old captures remain readable."
        }
      },
      "required": [
        "salt8",
        "ck_up"
      ],
      "additionalProperties": false
    }
  },
  "patternProperties": {
    "^\\d{1,5}$": {
      "$ref": "#/$defs/device_entry"
    }
  },
  "required": [
    "_meta"
  ],
  "additionalProperties": false
}
