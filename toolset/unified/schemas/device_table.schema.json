{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Device Table",
  "type": "object",
  "properties": {
    "_meta": {
      "type": "object",
      "properties": {
        "master_seed": {
          "type": "string",
          "pattern": "^[A-Za-z0-9+/]+=*$"
        },
        "version": {
          "const": "1.0"
        }
      },
      "required": [
        "master_seed",
        "version"
      ],
      "additionalProperties": false
    }
  },
  "definitions": {
    "deployment_metadata": {
      "type": "object",
      "properties": {
        "deployment_sensor_key": {
          "type": "string",
          "minLength": 1
        },
        "sensor_keys": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "sensors": {
          "type": [
            "object",
            "array"
          ]
        }
      },
      "required": [
        "deployment_sensor_key"
      ],
      "additionalProperties": false
    },
    "provisioning_metadata": {
      "type": "object",
      "properties": {
        "identity_pubkey": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "firmware_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32
        },
        "firmware_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "birth_cert_sig": {
          "type": "string",
          "pattern": "^[0-9a-f]{128}$"
        },
        "provisioned_at": {
          "type": "integer"
        },
        "site_id": {
          "type": "string"
        }
      },
      "required": [
        "identity_pubkey"
      ],
      "additionalProperties": false
    }
  },
  "patternProperties": {
    "^\\d{1,5}$": {
      "type": "object",
      "properties": {
        "salt8": {
          "type": "string",
          "pattern": "^[A-Za-z0-9+/]+=*$"
        },
        "ck_up": {
          "type": "string",
          "pattern": "^[A-Za-z0-9+/]+=*$"
        },
        "highest_fc_seen": {
          "type": [
            "integer",
            "number"
          ]
        },
        "last_seen": {
          "type": "string"
        },
        "msg_type": {
          "type": [
            "integer",
            "number"
          ]
        },
        "flags": {
          "type": [
            "integer",
            "number"
          ]
        },
        "site_id": {
          "type": "string"
        },
        "sensor_keys": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "sensors": {
          "type": [
            "object",
            "array"
          ]
        },
        "deployment": {
          "$ref": "#/definitions/deployment_metadata"
        },
        "provisioning": {
          "$ref": "#/definitions/provisioning_metadata"
        }
      },
      "required": [
        "salt8",
        "ck_up"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "_meta"
  ],
  "additionalProperties": false
}
