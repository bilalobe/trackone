{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/device_table.schema.json",
  "title": "Device Table",
  "type": "object",
  "properties": {
    "_meta": {
      "type": "object",
      "properties": {
        "master_seed": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/base64_string"
        },
        "version": {
          "const": "1.0"
        }
      },
      "required": [
        "master_seed",
        "version"
      ],
      "additionalProperties": false
    }
  },
  "$defs": {
    "provisioning_metadata": {
      "type": "object",
      "properties": {
        "identity_pubkey": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/hex64_lower"
        },
        "firmware_version": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/firmware_version"
        },
        "firmware_hash": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/hex64_lower"
        },
        "birth_cert_sig": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/hex128_lower"
        },
        "provisioned_at": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/integer_timestamp"
        },
        "site_id": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/site_id"
        }
      },
      "required": [
        "identity_pubkey"
      ],
      "additionalProperties": false
    },
    "device_entry": {
      "type": "object",
      "properties": {
        "salt8": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/base64_string"
        },
        "ck_up": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/base64_string"
        },
        "highest_fc_seen": {
          "type": [
            "integer",
            "number"
          ]
        },
        "last_seen": {
          "type": "string"
        },
        "msg_type": {
          "type": [
            "integer",
            "number"
          ]
        },
        "flags": {
          "type": [
            "integer",
            "number"
          ]
        },
        "site_id": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/site_id"
        },
        "sensor_keys": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/sensor_key_map"
        },
        "sensors": {
          "anyOf": [
            {
              "type": "object"
            },
            {
              "type": "array"
            }
          ]
        },
        "deployment": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/deployment_metadata"
        },
        "provisioning": {
          "$ref": "#/$defs/provisioning_metadata"
        }
      },
      "required": [
        "salt8",
        "ck_up"
      ],
      "additionalProperties": false
    }
  },
  "patternProperties": {
    "^\\d{1,5}$": {
      "$ref": "#/$defs/device_entry"
    }
  },
  "required": [
    "_meta"
  ],
  "additionalProperties": false
}
