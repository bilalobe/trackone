{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/peer_attest.schema.json",
  "title": "Peer Attestation",
  "description": "Co-signatures over a TrackOne day Merkle root by external peers.",
  "type": "object",
  "properties": {
    "day": {
      "$ref": "https://example.org/schemas/common.schema.json#/$defs/utc_date",
      "description": "UTC date (YYYY-MM-DD) this attestation covers."
    },
    "site_id": {
      "$ref": "https://example.org/schemas/common.schema.json#/$defs/site_id",
      "description": "Site identifier corresponding to the day record."
    },
    "day_root": {
      "$ref": "https://example.org/schemas/common.schema.json#/$defs/hex64_lower",
      "description": "Hex-encoded SHA-256 Merkle root for the day (matches day_record.day_root)."
    },
    "context": {
      "type": "string",
      "minLength": 1,
      "description": "Context string bound into the signed message (e.g. 'trackone:day-root:v1')."
    },
    "signatures": {
      "type": "array",
      "description": "List of peer co-signatures over (context, site_id, day, day_root).",
      "items": {
        "type": "object",
        "properties": {
          "peer_id": {
            "type": "string",
            "minLength": 1,
            "description": "Peer identifier (human-readable or stable ID)."
          },
          "signature_hex": {
            "$ref": "https://example.org/schemas/common.schema.json#/$defs/hex_lower",
            "description": "Hex-encoded Ed25519 signature over the attestation message."
          },
          "pubkey_hex": {
            "$ref": "https://example.org/schemas/common.schema.json#/$defs/hex64_lower",
            "description": "Hex-encoded Ed25519 public key for this peer (32 bytes)."
          }
        },
        "required": [
          "peer_id",
          "signature_hex",
          "pubkey_hex"
        ],
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "required": [
    "day",
    "site_id",
    "day_root",
    "context",
    "signatures"
  ],
  "additionalProperties": false
}
