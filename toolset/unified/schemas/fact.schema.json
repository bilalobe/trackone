{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/fact.schema.json",
  "title": "Telemetry Fact",
  "type": "object",
  "description": "Atomic telemetry fact produced by a pod device before batching/anchoring using the canonical TrackOne fact shape.",
  "properties": {
    "pod_id": {
      "$ref": "https://example.org/schemas/common.schema.json#/$defs/pod_id_hex16"
    },
    "fc": {
      "$ref": "https://example.org/schemas/common.schema.json#/$defs/non_negative_integer"
    },
    "ingest_time": {
      "$ref": "https://example.org/schemas/common.schema.json#/$defs/integer_timestamp"
    },
    "ingest_time_rfc3339_utc": {
      "$ref": "https://example.org/schemas/common.schema.json#/$defs/rfc3339_utc"
    },
    "pod_time": {
      "$ref": "https://example.org/schemas/common.schema.json#/$defs/nullable_integer_timestamp"
    },
    "kind": {
      "type": "string",
      "enum": [
        "env.sample",
        "pipeline.event",
        "health.status",
        "custom.raw"
      ]
    },
    "payload": {
      "type": "object",
      "additionalProperties": true
    },
    "signature": {
      "type": "string",
      "description": "Detached Ed25519 signature (hex/base64)."
    }
  },
  "required": [
    "pod_id",
    "fc",
    "ingest_time",
    "pod_time",
    "kind",
    "payload"
  ],
  "additionalProperties": false
}
