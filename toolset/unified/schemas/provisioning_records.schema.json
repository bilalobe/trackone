{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/provisioning_records.schema.json",
  "title": "Provisioning Records Bundle",
  "type": "object",
  "properties": {
    "version": {
      "const": 1
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "site_id": {
      "$ref": "https://example.org/schemas/common.schema.json#/$defs/site_id"
    },
    "records": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/provisioning_record"
      }
    }
  },
  "$defs": {
    "provisioning_record": {
      "type": "object",
      "properties": {
        "pod_id": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/pod_id_hex16"
        },
        "firmware_version": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/firmware_version"
        },
        "firmware_hash": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/hex64_lower"
        },
        "identity_pubkey": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/hex64_lower"
        },
        "birth_cert_sig": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/hex128_lower"
        },
        "provisioned_at": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/integer_timestamp"
        },
        "site_id": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/nullable_site_id"
        },
        "deployment": {
          "$ref": "https://example.org/schemas/common.schema.json#/$defs/deployment_metadata"
        }
      },
      "required": [
        "pod_id",
        "firmware_version",
        "firmware_hash",
        "identity_pubkey",
        "birth_cert_sig",
        "provisioned_at",
        "deployment"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "version",
    "records"
  ],
  "additionalProperties": false
}
