{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/common.schema.json",
  "title": "TrackOne Common Schema Components",
  "$defs": {
    "utc_date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "rfc3339_utc": {
      "type": "string",
      "format": "date-time"
    },
    "base64_string": {
      "type": "string",
      "pattern": "^[A-Za-z0-9+/]+=*$"
    },
    "hex64_mixed": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{64}$"
    },
    "hex_lower": {
      "type": "string",
      "pattern": "^[0-9a-f]+$"
    },
    "hex64_lower": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "hex128_lower": {
      "type": "string",
      "pattern": "^[0-9a-f]{128}$"
    },
    "pod_id_hex16": {
      "type": "string",
      "pattern": "^[0-9a-f]{16}$"
    },
    "firmware_version": {
      "type": "string",
      "minLength": 1,
      "maxLength": 32
    },
    "site_id": {
      "type": "string",
      "minLength": 1
    },
    "trackone_entity_id": {
      "type": "string",
      "pattern": "^trackone:[a-z-]+:[0-9a-f]{64}$"
    },
    "nullable_site_id": {
      "anyOf": [
        {
          "$ref": "#/$defs/site_id"
        },
        {
          "type": "null"
        }
      ]
    },
    "integer_timestamp": {
      "type": "integer"
    },
    "artifact_ref": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "sha256": {
          "$ref": "#/$defs/hex64_lower"
        }
      },
      "required": [
        "path",
        "sha256"
      ],
      "additionalProperties": false
    },
    "nullable_integer_timestamp": {
      "anyOf": [
        {
          "$ref": "#/$defs/integer_timestamp"
        },
        {
          "type": "null"
        }
      ]
    },
    "non_negative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "sensor_key": {
      "type": "string",
      "minLength": 1
    },
    "sensor_key_map": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/sensor_key"
      }
    },
    "deployment_metadata": {
      "type": "object",
      "properties": {
        "deployment_sensor_key": {
          "$ref": "#/$defs/sensor_key"
        },
        "sensor_keys": {
          "$ref": "#/$defs/sensor_key_map"
        },
        "sensors": {
          "anyOf": [
            {
              "type": "array"
            },
            {
              "type": "object"
            }
          ]
        }
      },
      "required": [
        "deployment_sensor_key"
      ],
      "additionalProperties": false
    },
    "provisioning_metadata": {
      "type": "object",
      "properties": {
        "identity_pubkey": {
          "$ref": "#/$defs/hex64_lower"
        },
        "firmware_version": {
          "$ref": "#/$defs/firmware_version"
        },
        "firmware_hash": {
          "$ref": "#/$defs/hex64_lower"
        },
        "birth_cert_sig": {
          "$ref": "#/$defs/hex128_lower"
        },
        "provisioned_at": {
          "$ref": "#/$defs/integer_timestamp"
        },
        "site_id": {
          "$ref": "#/$defs/site_id"
        }
      },
      "required": [
        "identity_pubkey",
        "firmware_version",
        "firmware_hash",
        "birth_cert_sig",
        "provisioned_at"
      ],
      "additionalProperties": false
    },
    "leaf_hashes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/hex64_lower"
      }
    },
    "block_header_v1": {
      "type": "object",
      "properties": {
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "site_id": {
          "$ref": "#/$defs/site_id"
        },
        "day": {
          "$ref": "#/$defs/utc_date"
        },
        "batch_id": {
          "type": "string",
          "minLength": 1
        },
        "merkle_root": {
          "$ref": "#/$defs/hex64_lower"
        },
        "count": {
          "$ref": "#/$defs/non_negative_integer"
        },
        "leaf_hashes": {
          "$ref": "#/$defs/leaf_hashes"
        }
      },
      "required": [
        "version",
        "site_id",
        "day",
        "batch_id",
        "merkle_root",
        "count",
        "leaf_hashes"
      ],
      "additionalProperties": false
    }
  }
}
