; TrackOne authoritative CBOR commitment family.
; Scope of this file:
; - env-fact-v1
; - fact-v1
; - block-header-v1
; - day-record-v1
;
; This file intentionally covers only the CBOR-authoritative commitment family.
; JSON projections and operational JSON artifacts remain specified by JSON Schema.
;
; Notes:
; - env-fact-v1 and fact-v1 model the positional array encodings implemented in
;   crates/trackone-core/src/cbor.rs
; - block-header-v1 and day-record-v1 model the canonical CBOR map structure of
;   the Rust ledger types in crates/trackone-ledger/src/types.rs
; - String lexical constraints (for example lowercase hex) are enforced by the
;   JSON Schema and implementation layers; the first CDDL pass stays structural
;   so it remains portable and parser-friendly.

pod-id = bstr .size 8
timestamp = int
non-negative = uint
hex-string = tstr
site-id = tstr
day-label = tstr
batch-id = tstr

sample-type = 1..10 / 250
fact-kind = 1 / 2 / 3 / 250

float-or-nil = float / nil
uint-or-nil = uint / nil
time-or-nil = int / nil

env-fact-v1 = [
  1,
  sample-type,
  timestamp,
  timestamp,
  float-or-nil,
  float-or-nil,
  float-or-nil,
  float-or-nil,
  uint-or-nil,
  float-or-nil,
  uint-or-nil,
]

fact-payload-v1 = [
  0,
  env-fact-v1
] / [
  1,
  bstr
]

fact-v1 = [
  1,
  pod-id,
  non-negative,
  timestamp,
  time-or-nil,
  fact-kind,
  fact-payload-v1,
]

block-header-v1 = {
  "version": uint,
  "site_id": site-id,
  "day": day-label,
  "batch_id": batch-id,
  "merkle_root": hex-string,
  "count": uint,
  "leaf_hashes": [* hex-string],
}

day-record-v1 = {
  "version": uint,
  "site_id": site-id,
  "date": day-label,
  "prev_day_root": hex-string,
  "batches": [+ block-header-v1],
  "day_root": hex-string,
}
